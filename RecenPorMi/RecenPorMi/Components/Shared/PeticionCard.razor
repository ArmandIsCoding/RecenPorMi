@using RecenPorMi.Data.Models
@using Microsoft.AspNetCore.SignalR.Client
@inject RecenPorMi.Services.IPeticionService PeticionService
@inject NavigationManager NavigationManager

<div class="peticion-card">
    <div class="peticion-header">
        <div class="d-flex align-items-center gap-2 mb-2">
            <span class="peticion-alias">@ObtenerNombreAutor()</span>
            @if (!string.IsNullOrEmpty(Peticion.ContenidoCompleto))
            {
                <span class="badge bg-info text-xs">📄 Con detalles</span>
            }
            @if (Peticion.Imagenes?.Any() == true)
            {
                <span class="badge bg-success text-xs">📷 @Peticion.Imagenes.Count</span>
            }
        </div>
        <span class="peticion-fecha">@FormatearFecha(Peticion.FechaPublicacion)</span>
    </div>

    <div class="peticion-contenido">
        @Peticion.DescripcionBreve
    </div>

    <!-- Thumbnail de primera imagen si existe -->
    @if (Peticion.Imagenes?.Any() == true)
    {
        var primeraImagen = Peticion.Imagenes.OrderBy(i => i.Orden).FirstOrDefault();
        if (primeraImagen != null)
        {
            <div class="peticion-imagen-preview mb-2">
                <img src="@primeraImagen.RutaImagen" 
                     alt="Vista previa" 
                     class="img-fluid rounded"
                     style="max-height: 150px; width: 100%; object-fit: cover;" />
            </div>
        }
    }

    <div class="peticion-footer">
        <div class="d-flex justify-content-between align-items-center">
            <button class="btn-rezo @(rezando ? "rezando" : "")" 
                    @onclick="Rezar" 
                    disabled="@rezando">
                <span class="emoji-rezo">🙏</span>
                <span class="contador">@contadorLocal</span>
            </button>

            <a href="/intenciones/@Peticion.Id" class="btn-ver-detalles">
                Ver detalles <span class="ms-1">→</span>
            </a>
        </div>

        @if (!string.IsNullOrEmpty(mensaje))
        {
            <div class="mensaje-rezo mt-2">@mensaje</div>
        }
    </div>
</div>

<style>
    .text-xs {
        font-size: 0.7rem;
        padding: 0.2rem 0.4rem;
    }

    .btn-ver-detalles {
        color: var(--primary-color, #6f42c1);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: all 0.2s;
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
    }

    .btn-ver-detalles:hover {
        background: rgba(111, 66, 193, 0.1);
        transform: translateX(2px);
    }

    .peticion-imagen-preview {
        margin-top: 0.75rem;
        overflow: hidden;
        border-radius: 8px;
    }

    .peticion-contenido {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        max-height: 4.5em;
        line-height: 1.5em;
    }
</style>

@code {
    [Parameter]
    public Peticion Peticion { get; set; } = null!;

    [Parameter]
    public HubConnection? HubConnection { get; set; }

    [Parameter]
    public EventCallback OnRezoRegistrado { get; set; }

    private int contadorLocal;
    private bool rezando = false;
    private string mensaje = string.Empty;

    protected override void OnInitialized()
    {
        contadorLocal = Peticion.ContadorRezos;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && HubConnection != null)
        {
            HubConnection.On<int, int>("RezoActualizado", (peticionId, nuevoContador) =>
            {
                if (peticionId == Peticion.Id)
                {
                    contadorLocal = nuevoContador;
                    InvokeAsync(StateHasChanged);
                }
            });
        }
    }

    private async Task Rezar()
    {
        if (rezando) return;

        rezando = true;
        mensaje = string.Empty;
        StateHasChanged();

        try
        {
            var ipAddress = "127.0.0.1"; // En producción, obtener la IP real del usuario
            var exito = await PeticionService.RegistrarRezoAsync(Peticion.Id, ipAddress);

            if (exito)
            {
                contadorLocal++;
                mensaje = "🕊️ Tu oración ha sido registrada";

                // Notificar a través de SignalR
                if (HubConnection != null && HubConnection.State == HubConnectionState.Connected)
                {
                    await HubConnection.SendAsync("NotificarRezoActualizado", Peticion.Id, contadorLocal);
                }

                await OnRezoRegistrado.InvokeAsync();
            }
            else
            {
                mensaje = "Ya rezaste por esta intención recientemente";
            }
        }
        catch (Exception ex)
        {
            mensaje = "Error al registrar el rezo";
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            rezando = false;
            StateHasChanged();

            // Limpiar mensaje después de 3 segundos
            await Task.Delay(3000);
            mensaje = string.Empty;
            StateHasChanged();
        }
    }

    private string FormatearFecha(DateTime fecha)
    {
        var diferencia = DateTime.Now - fecha;

        if (diferencia.TotalMinutes < 1)
            return "Hace un momento";
        if (diferencia.TotalHours < 1)
            return $"Hace {(int)diferencia.TotalMinutes} min";
        if (diferencia.TotalDays < 1)
            return $"Hace {(int)diferencia.TotalHours}h";
        if (diferencia.TotalDays < 7)
            return $"Hace {(int)diferencia.TotalDays}d";

        return fecha.ToString("dd/MM/yyyy");
    }

    private string ObtenerNombreAutor()
    {
        if (Peticion.PublicarAnonimamente)
        {
            return "Anónimo";
        }

        // ✅ Mostrar DisplayName en lugar del email
        return Peticion.Usuario?.DisplayName ?? "Usuario";
    }
}
